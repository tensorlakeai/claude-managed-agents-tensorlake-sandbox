ANTHROPIC_ENVIRONMENT_ID=env_xxx
ANTHROPIC_ENVIRONMENT_KEY=sk-ant-env-xxx
ANTHROPIC_WEBHOOK_SIGNING_KEY=whsec_xxx
TENSORLAKE_API_KEY=tl_xxx
SANDBOX_IMAGE_NAME=agent-cli
# Webhook-in-sandbox mode: idle timeout before suspend (default 600s).
# Set 60 temporarily to make the wake-on-request test turn around in minutes.
#WEBHOOK_SANDBOX_TIMEOUT_SECONDS=60
# Long-running sessions: resume the per-session sandbox after it auto-suspends
# instead of recreating it from the base image (state intact, sub-second wake).
# Default false (clean slate per burst). Set true when the session's in-sandbox
# state (cloned repo, installed deps, scratch files) should persist across idle gaps.
#RESUME_SUSPENDED_SESSIONS=true
